{
  "type": "excalidraw",
  "version": 2,
  "source": "claude",
  "elements": [
    {
      "type": "text",
      "id": "title",
      "x": 40,
      "y": 20,
      "width": 900,
      "height": 50,
      "text": "Streaming Board: 2D chunked sliding window over a scratch file",
      "fontSize": 24,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top"
    },
    {
      "type": "text",
      "id": "subtitle",
      "x": 40,
      "y": 80,
      "width": 1100,
      "height": 60,
      "text": "Auto-promotes when an --initial-board run exceeds --max-board-memory. Keeps RAM bounded by paging\na small chunk of cells in and out of a binary scratch file on disk.",
      "fontSize": 14,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top"
    },

    {
      "type": "rectangle",
      "id": "rule",
      "x": 40,
      "y": 170,
      "width": 260,
      "height": 90,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "roundness": { "type": 3 },
      "boundElements": [{"type": "text", "id": "rule_label"}]
    },
    {
      "type": "text",
      "id": "rule_label",
      "x": 40,
      "y": 170,
      "width": 260,
      "height": 90,
      "text": "CellRule\n(InPlaceTransitionalUpdater)\nnext_state(alive, neighbors) -> alive",
      "fontSize": 13,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "rule"
    },

    {
      "type": "arrow",
      "id": "rule_to_board",
      "x": 305,
      "y": 215,
      "width": 80,
      "height": 0,
      "strokeColor": "#1e1e1e",
      "strokeWidth": 2,
      "points": [[0, 0], [80, 0]],
      "startBinding": {"elementId": "rule", "focus": 0, "gap": 5},
      "endBinding": {"elementId": "board_editor", "focus": 0, "gap": 5}
    },
    {
      "type": "text",
      "id": "rule_arrow_label",
      "x": 305,
      "y": 180,
      "width": 200,
      "height": 30,
      "text": "advance_with_rule(&dyn CellRule)",
      "fontSize": 11,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top"
    },

    {
      "type": "rectangle",
      "id": "board_editor",
      "x": 390,
      "y": 170,
      "width": 260,
      "height": 90,
      "strokeColor": "#0c8599",
      "backgroundColor": "#99e9f2",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "roundness": { "type": 3 },
      "boundElements": [{"type": "text", "id": "board_editor_label"}]
    },
    {
      "type": "text",
      "id": "board_editor_label",
      "x": 390,
      "y": 170,
      "width": 260,
      "height": 90,
      "text": "BoardEditor (trait)\nobject-safe via &dyn CellRule\nboard owns iteration",
      "fontSize": 13,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "board_editor"
    },

    {
      "type": "rectangle",
      "id": "inmem_impl",
      "x": 720,
      "y": 130,
      "width": 240,
      "height": 60,
      "strokeColor": "#495057",
      "backgroundColor": "#dee2e6",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "roundness": { "type": 3 },
      "boundElements": [{"type": "text", "id": "inmem_label"}]
    },
    {
      "type": "text",
      "id": "inmem_label",
      "x": 720,
      "y": 130,
      "width": 240,
      "height": 60,
      "text": "InMemoryBoard\n(when board fits in cap)",
      "fontSize": 12,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "inmem_impl"
    },

    {
      "type": "rectangle",
      "id": "stream_impl",
      "x": 720,
      "y": 230,
      "width": 240,
      "height": 60,
      "strokeColor": "#e67700",
      "backgroundColor": "#fff3bf",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "roundness": { "type": 3 },
      "boundElements": [{"type": "text", "id": "stream_label"}]
    },
    {
      "type": "text",
      "id": "stream_label",
      "x": 720,
      "y": 230,
      "width": 240,
      "height": 60,
      "text": "StreamingBoard\n(when board > cap)",
      "fontSize": 12,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "stream_impl"
    },

    {
      "type": "arrow",
      "id": "editor_to_inmem",
      "x": 655,
      "y": 200,
      "width": 65,
      "height": -35,
      "strokeColor": "#495057",
      "strokeWidth": 1,
      "points": [[0, 0], [65, -35]],
      "startBinding": {"elementId": "board_editor", "focus": 0, "gap": 5},
      "endBinding": {"elementId": "inmem_impl", "focus": 0, "gap": 5}
    },
    {
      "type": "arrow",
      "id": "editor_to_stream",
      "x": 655,
      "y": 230,
      "width": 65,
      "height": 30,
      "strokeColor": "#e67700",
      "strokeWidth": 2,
      "points": [[0, 0], [65, 30]],
      "startBinding": {"elementId": "board_editor", "focus": 0, "gap": 5},
      "endBinding": {"elementId": "stream_impl", "focus": 0, "gap": 5}
    },

    {
      "type": "text",
      "id": "promote_label",
      "x": 40,
      "y": 320,
      "width": 1100,
      "height": 30,
      "text": "Auto-promote when: --initial-board AND (width * height * size_of::<CellState>()) > --max-board-memory",
      "fontSize": 13,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top"
    },

    {
      "type": "rectangle",
      "id": "stream_internals",
      "x": 40,
      "y": 380,
      "width": 600,
      "height": 460,
      "strokeColor": "#e67700",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roundness": { "type": 3 }
    },
    {
      "type": "text",
      "id": "stream_internals_title",
      "x": 60,
      "y": 395,
      "width": 580,
      "height": 30,
      "text": "StreamingBoard internals",
      "fontSize": 18,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top"
    },

    {
      "type": "rectangle",
      "id": "chunk_visual",
      "x": 70,
      "y": 445,
      "width": 280,
      "height": 220,
      "strokeColor": "#1864ab",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roundness": { "type": 3 }
    },
    {
      "type": "text",
      "id": "chunk_label",
      "x": 80,
      "y": 455,
      "width": 260,
      "height": 30,
      "text": "Chunk InMemoryBoard (max loaded extent)",
      "fontSize": 12,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top"
    },

    {
      "type": "rectangle",
      "id": "halo_top",
      "x": 90,
      "y": 495,
      "width": 240,
      "height": 30,
      "strokeColor": "#862e9c",
      "backgroundColor": "#f3d9fa",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "boundElements": [{"type": "text", "id": "halo_top_label"}]
    },
    {
      "type": "text",
      "id": "halo_top_label",
      "x": 90,
      "y": 495,
      "width": 240,
      "height": 30,
      "text": "halo (read-only)",
      "fontSize": 11,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "halo_top"
    },

    {
      "type": "rectangle",
      "id": "halo_left",
      "x": 90,
      "y": 525,
      "width": 30,
      "height": 100,
      "strokeColor": "#862e9c",
      "backgroundColor": "#f3d9fa",
      "fillStyle": "hachure",
      "strokeWidth": 1
    },
    {
      "type": "rectangle",
      "id": "owned",
      "x": 120,
      "y": 525,
      "width": 180,
      "height": 100,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "boundElements": [{"type": "text", "id": "owned_label"}]
    },
    {
      "type": "text",
      "id": "owned_label",
      "x": 120,
      "y": 525,
      "width": 180,
      "height": 100,
      "text": "owned\ncells\n(updatable\nthis pass)",
      "fontSize": 12,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "owned"
    },
    {
      "type": "rectangle",
      "id": "halo_right",
      "x": 300,
      "y": 525,
      "width": 30,
      "height": 100,
      "strokeColor": "#862e9c",
      "backgroundColor": "#f3d9fa",
      "fillStyle": "hachure",
      "strokeWidth": 1
    },
    {
      "type": "rectangle",
      "id": "halo_bottom",
      "x": 90,
      "y": 625,
      "width": 240,
      "height": 30,
      "strokeColor": "#862e9c",
      "backgroundColor": "#f3d9fa",
      "fillStyle": "hachure",
      "strokeWidth": 1
    },

    {
      "type": "text",
      "id": "halo_note",
      "x": 70,
      "y": 680,
      "width": 280,
      "height": 60,
      "text": "Halo = real in-board neighbors\nfor the 3x3 Conway stencil.\nOut-of-board halo is NEVER stored;\nthe streaming board's bounds\ncheck returns Dead directly.",
      "fontSize": 11,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top"
    },

    {
      "type": "rectangle",
      "id": "metadata_box",
      "x": 370,
      "y": 445,
      "width": 250,
      "height": 230,
      "strokeColor": "#0c8599",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roundness": { "type": 3 }
    },
    {
      "type": "text",
      "id": "metadata_title",
      "x": 380,
      "y": 455,
      "width": 230,
      "height": 30,
      "text": "Chunk position metadata",
      "fontSize": 13,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top"
    },
    {
      "type": "text",
      "id": "metadata_body",
      "x": 380,
      "y": 495,
      "width": 230,
      "height": 170,
      "text": "owned_origin (y, x)\nowned_size (rows, cols)\nloaded_origin (y, x)\nloaded_size (rows, cols)\n\nAll usize (no negative coords).\nDirty bits per owned row.\n\nGlobal -> local:\n  (x - loaded_origin.1,\n   y - loaded_origin.0)",
      "fontSize": 11,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top"
    },

    {
      "type": "text",
      "id": "slide_note",
      "x": 370,
      "y": 690,
      "width": 250,
      "height": 130,
      "text": "Slide pattern (mark pass):\nfor y in chunk row-bands:\n  for x in chunk cols (if 2D):\n    flush dirty rows\n    load new chunk\n    mark owned cells\n\nRow-band fast path:\nchunk_cols == width => no\nhorizontal sliding.",
      "fontSize": 11,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top"
    },

    {
      "type": "rectangle",
      "id": "scratch_box",
      "x": 700,
      "y": 380,
      "width": 480,
      "height": 460,
      "strokeColor": "#e67700",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roundness": { "type": 3 }
    },
    {
      "type": "text",
      "id": "scratch_title",
      "x": 720,
      "y": 395,
      "width": 440,
      "height": 30,
      "text": "Scratch file (GOL-SCRATCH v1, binary)",
      "fontSize": 18,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top"
    },

    {
      "type": "rectangle",
      "id": "header_box",
      "x": 720,
      "y": 445,
      "width": 440,
      "height": 140,
      "strokeColor": "#1864ab",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "boundElements": [{"type": "text", "id": "header_label"}]
    },
    {
      "type": "text",
      "id": "header_label",
      "x": 720,
      "y": 445,
      "width": 440,
      "height": 140,
      "text": "Header (64 bytes)\nmagic = 'GOL-SCRATCH v1\\n\\0'\nschema_version  u32 LE\ncreated_at_unix u64 LE\nwidth           u64 LE\nheight          u64 LE\nrow_bytes       u64 LE  (ceil(width*2/8))",
      "fontSize": 12,
      "fontFamily": 3,
      "strokeColor": "#000000",
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "header_box"
    },

    {
      "type": "rectangle",
      "id": "payload_box",
      "x": 720,
      "y": 595,
      "width": 440,
      "height": 130,
      "strokeColor": "#0c8599",
      "backgroundColor": "#99e9f2",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "boundElements": [{"type": "text", "id": "payload_label"}]
    },
    {
      "type": "text",
      "id": "payload_label",
      "x": 720,
      "y": 595,
      "width": 440,
      "height": 130,
      "text": "Row payloads (height x row_bytes, fixed stride)\n2 bits per cell, 4 cells per byte\n00=Dead  01=Alive  10=Dying  11=Resurrecting\n\nRandom-access row offset:\n  64 + y * row_bytes",
      "fontSize": 12,
      "fontFamily": 3,
      "strokeColor": "#000000",
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "payload_box"
    },

    {
      "type": "text",
      "id": "rmw_note",
      "x": 720,
      "y": 740,
      "width": 440,
      "height": 90,
      "text": "Sub-byte writes use read-modify-write\nfor boundary bytes so bits belonging\nto cells outside the write range are\npreserved.",
      "fontSize": 11,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top"
    },

    {
      "type": "arrow",
      "id": "chunk_to_scratch",
      "x": 640,
      "y": 555,
      "width": 60,
      "height": 0,
      "strokeColor": "#e67700",
      "strokeWidth": 2,
      "points": [[0, 0], [60, 0]],
      "startBinding": {"elementId": "stream_internals", "focus": 0, "gap": 5},
      "endBinding": {"elementId": "scratch_box", "focus": 0, "gap": 5}
    },
    {
      "type": "text",
      "id": "chunk_to_scratch_label",
      "x": 640,
      "y": 510,
      "width": 60,
      "height": 50,
      "text": "row\nreads /\nwrites",
      "fontSize": 10,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "center",
      "verticalAlign": "top"
    },

    {
      "type": "rectangle",
      "id": "footer_box",
      "x": 40,
      "y": 870,
      "width": 1140,
      "height": 90,
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roundness": { "type": 3 }
    },
    {
      "type": "text",
      "id": "footer_text",
      "x": 60,
      "y": 885,
      "width": 1100,
      "height": 65,
      "text": "Lifecycle: scratch lives in --working-dir (default OS temp), named gol-scratch-<run-id>-<random>.bin so concurrent runs never collide.\nAuto-deleted on successful completion. Preserved on any failure (panic / Ctrl-C / SIGKILL / I/O error) for debugging.\nMemory cap (--max-board-memory) governs chunk RAM only, using size_of::<CellState>() per cell. Disk packing is irrelevant to RAM accounting.",
      "fontSize": 11,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top"
    }
  ],
  "appState": {"viewBackgroundColor": "#ffffff"}
}
