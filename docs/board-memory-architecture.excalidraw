    {
      "type": "text",
      "id": "footer",
      "x": 40,
      "y": 680,
      "width": 1140,
      "height": 60,
      "text": "All initializers implement BoardInitializer::initialize<B: BoardEditor + ?Sized>, so they work uniformly on\nInMemoryBoard and StreamingBoard. New seeders can be added without touching board storage.",
      "fontSize": 12,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top"
    }
  ],
  "appState": {"viewBackgroundColor": "#ffffff"}
