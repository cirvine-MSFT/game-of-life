    },
    {
      "type": "text",
      "id": "init_alive_label",
      "x": 320,
      "y": 540,
      "width": 260,
      "height": 100,
      "text": "--initial-board alive\nFullyAliveInitializer\nevery cell starts Alive\n(overpopulation demo)",
      "fontSize": 12,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "center",
