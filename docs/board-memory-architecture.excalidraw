      "x": 600,
      "y": 540,
      "width": 260,
      "height": 100,
      "text": "--initial-board blinker\nBlinkerBoardInitializer\nsingle centered horizontal\n3-cell oscillator",
      "fontSize": 12,
      "fontFamily": 1,
      "strokeColor": "#000000",
