      "backgroundColor": "#99e9f2",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "boundElements": [{"type": "text", "id": "sniff_label"}]
    },
    {
      "type": "text",
      "id": "sniff_label",
      "x": 60,
      "y": 540,
      "width": 200,
      "height": 80,
      "text": "Magic sniff\n(first 128 bytes)\nidentify FileKind",
      "fontSize": 12,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "sniff"
    },
