      "type": "text",
      "id": "size_guard_label",
      "x": 330,
      "y": 540,
      "width": 200,
      "height": 80,
      "text": "File-size guard\n--max-input-file-bytes\n(default 256MB)",
      "fontSize": 12,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "center",
      "verticalAlign": "middle",
