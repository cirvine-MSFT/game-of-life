      "type": "rectangle",
      "id": "hash_check",
      "x": 870,
      "y": 540,
      "width": 290,
      "height": 80,
      "strokeColor": "#e67700",
      "backgroundColor": "#fff3bf",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "boundElements": [{"type": "text", "id": "hash_label"}]
    },
    {
      "type": "text",
      "id": "hash_label",
      "x": 870,
      "y": 540,
      "width": 290,
      "height": 80,
      "text": "content_hash check (run records only)\nIntegrityMode: Enforce / Warn / Ignore\nMismatch -> Corrupted error or warning",
      "fontSize": 12,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "hash_check"
    },

    {
      "type": "text",
      "id": "verbs_title",
      "x": 40,
      "y": 680,
      "width": 1140,
      "height": 30,
      "text": "CLI verbs and load paths",
      "fontSize": 16,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top"
    },
    {
      "type": "rectangle",
      "id": "verbs_box",
      "x": 40,
      "y": 720,
      "width": 1140,
      "height": 140,
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roundness": { "type": 3 }
    },
    {
      "type": "text",
      "id": "verbs_text",
      "x": 60,
      "y": 735,
      "width": 1100,
      "height": 115,
      "text": "--load-board <PATH>     load snapshot OR run record (--load-from initial|final) as initial board\n--continue <PATH>       load run record's FINAL board, chain into a new run; records continued_from\n--replay <PATH>         re-execute and diff the saved final board + key stats\n--extract-board <PATH>  copy a run record's INITIAL/FINAL block out as a hand-editable snapshot\n--ignore-integrity      bypass content_hash check (warns on stderr)\nAuto-save: every successful run records its config + stats + boards into ./runs/<UTC>-<short-id>.gol",
      "fontSize": 12,
      "fontFamily": 3,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top"
    }
  ],
  "appState": {"viewBackgroundColor": "#ffffff"}
}
