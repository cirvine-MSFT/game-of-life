      "type": "rectangle",
      "id": "size_guard",
      "x": 330,
      "y": 540,
      "width": 200,
      "height": 80,
      "strokeColor": "#0c8599",
      "backgroundColor": "#99e9f2",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "boundElements": [{"type": "text", "id": "size_guard_label"}]
    },
