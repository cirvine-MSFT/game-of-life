      "startBinding": {"elementId": "size_guard", "focus": 0, "gap": 5},
      "endBinding": {"elementId": "parser", "focus": 0, "gap": 5}
    },
    {
      "type": "rectangle",
      "id": "parser",
      "x": 600,
      "y": 540,
      "width": 200,
      "height": 80,
      "strokeColor": "#0c8599",
      "backgroundColor": "#99e9f2",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "boundElements": [{"type": "text", "id": "parser_label"}]
    },
    {
      "type": "text",
      "id": "parser_label",
      "x": 600,
      "y": 540,
      "width": 200,
      "height": 80,
      "text": "Line-oriented parser\nfences + key/value\nmemory-budget check",
      "fontSize": 12,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "parser"
