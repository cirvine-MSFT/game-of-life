{
  "type": "excalidraw",
  "version": 2,
  "source": "claude",
  "elements": [
    {
      "type": "text",
      "id": "title",
      "x": 40,
      "y": 20,
      "width": 900,
      "height": 50,
      "text": "Persistence: snapshot vs run record (back-fill for PR #7)",
      "fontSize": 24,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top"
    },
    {
      "type": "text",
      "id": "subtitle",
      "x": 40,
      "y": 80,
      "width": 1100,
      "height": 40,
      "text": "Two file kinds share one parser pair. Snapshots are hand-editable, hash-free. Run records carry config + stats +\nboard blocks and are protected by a content_hash trailer (FNV-1a 64-bit).",
      "fontSize": 13,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top"
    },

    {
      "type": "rectangle",
      "id": "snapshot_box",
      "x": 40,
      "y": 150,
      "width": 480,
      "height": 280,
      "strokeColor": "#1864ab",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roundness": { "type": 3 }
    },
    {
      "type": "text",
      "id": "snapshot_title",
      "x": 60,
      "y": 165,
      "width": 440,
      "height": 30,
      "text": "Board snapshot (GOL-BOARD-SNAPSHOT v1)",
      "fontSize": 16,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top"
    },
    {
      "type": "rectangle",
      "id": "snapshot_body",
      "x": 60,
      "y": 210,
      "width": 440,
      "height": 200,
      "strokeColor": "#1864ab",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "boundElements": [{"type": "text", "id": "snapshot_body_text"}]
    },
    {
      "type": "text",
      "id": "snapshot_body_text",
      "x": 60,
      "y": 210,
      "width": 440,
      "height": 200,
      "text": "GOL-BOARD-SNAPSHOT v1\nschema_version: 1\ncreated_at: 2026-06-12T22:55:20Z\n\n----- BEGIN BOARD -----\nsize: WxH\nencoding: ascii\nalive_count / dead_count\n#./# grid rows\n----- END BOARD -----\n\nNo content_hash. Hand-editable.",
      "fontSize": 12,
      "fontFamily": 3,
      "strokeColor": "#000000",
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "snapshot_body"
    },

    {
      "type": "rectangle",
      "id": "runrec_box",
      "x": 580,
      "y": 150,
      "width": 600,
      "height": 280,
      "strokeColor": "#862e9c",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roundness": { "type": 3 }
    },
    {
      "type": "text",
      "id": "runrec_title",
      "x": 600,
      "y": 165,
      "width": 560,
      "height": 30,
      "text": "Run record (GOL-RUN-RECORD v1)",
      "fontSize": 16,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top"
    },
    {
      "type": "rectangle",
      "id": "runrec_body",
      "x": 600,
      "y": 210,
      "width": 560,
      "height": 200,
      "strokeColor": "#862e9c",
      "backgroundColor": "#f3d9fa",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "boundElements": [{"type": "text", "id": "runrec_body_text"}]
    },
    {
      "type": "text",
      "id": "runrec_body_text",
      "x": 600,
      "y": 210,
      "width": 560,
      "height": 200,
      "text": "GOL-RUN-RECORD v1\n[config] / [tool] / [result] / [continuation]\n----- BEGIN INITIAL BOARD ----- ... END\n----- BEGIN FINAL BOARD -----   ... END\n\ncontent_hash: <FNV-1a 64-bit, over canonicalized bytes>\n\nPer-grid hashes (initial_board_hash, final_board_hash)\nfor cross-reference / dedup.",
      "fontSize": 12,
      "fontFamily": 3,
      "strokeColor": "#000000",
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "runrec_body"
    },

    {
      "type": "rectangle",
      "id": "pipeline_box",
      "x": 40,
      "y": 470,
      "width": 1140,
      "height": 180,
      "strokeColor": "#0c8599",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roundness": { "type": 3 }
    },
    {
      "type": "text",
      "id": "pipeline_title",
      "x": 60,
      "y": 485,
      "width": 1100,
      "height": 30,
      "text": "Read pipeline (both file types)",
      "fontSize": 16,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top"
    },

