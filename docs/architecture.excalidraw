    {
      "type": "text",
      "id": "mark_pass_text",
      "x": 390,
      "y": 195,
      "width": 280,
      "height": 100,
      "text": "For each cell:\n1. Count live neighbors\n   (Alive + Dying = live)\n2. Apply Conway rules\n3. Set transitional state",
      "fontSize": 12,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top"
    },
    {
