    {
      "type": "text",
      "id": "cell_states_text",
      "x": 40,
      "y": 195,
      "width": 260,
      "height": 100,
      "text": "CellState Enum:\n• Dead (0 neighbors or >3)\n• Alive (2-3 neighbors)\n• Dying (temp: will be Dead)\n• Resurrecting (temp: will be Alive)",
      "fontSize": 12,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "textAlign": "left",
      "verticalAlign": "top"
    },
    {
      "type": "rectangle",
      "id": "mark_pass_container",
